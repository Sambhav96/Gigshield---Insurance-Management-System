# --- APP CONFIG --------------------------------------------------------------
# Runtime environment (development | staging | production)
ENV=development
# Human-readable backend service name
APP_NAME=GigShield Backend
# Base prefix for versioned API routes
API_V1_PREFIX=/api/v1

# --- SERVER ------------------------------------------------------------------
# Bind address for FastAPI/Uvicorn
HOST=0.0.0.0
# Backend HTTP port
PORT=8000

# --- DATABASE (SUPABASE / POSTGRES) -----------------------------------------
# Direct PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname
# PgBouncer / pooler connection string
DATABASE_URL_POOLER=postgresql://user:password@host:6543/dbname

# --- SUPABASE CONFIG ---------------------------------------------------------
# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co
# Public anon key (safe for client usage, still keep managed)
SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-side only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase JWT secret for token verification
SUPABASE_JWT_SECRET=your-jwt-secret

# --- JWT AUTH ----------------------------------------------------------------
# Backend signing secret for access tokens
JWT_SECRET_KEY=your-super-secret-key
# JWT signing algorithm
JWT_ALGORITHM=HS256
# Access token validity in minutes (10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- REDIS / CELERY ----------------------------------------------------------
# Redis connection used by cache/session layers
REDIS_URL=redis://default:password@host:6379
# Celery broker URL (queue transport)
CELERY_BROKER_URL=redis://default:password@host:6379/0
# Celery result backend URL (task results)
CELERY_RESULT_BACKEND=redis://default:password@host:6379/1

# --- RAZORPAY ----------------------------------------------------------------
# Razorpay key ID (public identifier)
RAZORPAY_KEY_ID=your-key-id
# Razorpay key secret (server-side only)
RAZORPAY_KEY_SECRET=your-key-secret
# Razorpay webhook signature secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Razorpay source account number for payouts
RAZORPAY_ACCOUNT_NUMBER=your-account-number

# --- WEATHER / EXTERNAL APIS -------------------------------------------------
# OpenWeather API key
OPENWEATHER_API_KEY=your-openweather-key
# AQI provider API key
AQI_API_KEY=your-aqi-key
# Google Routes API key
GOOGLE_ROUTES_API_KEY=your-google-routes-key
# Weatherstack API key
WEATHERSTACK_API_KEY=your-weatherstack-key

# --- NDMA / DISASTER API -----------------------------------------------------
# NDMA disaster feed base URL
NDMA_API_URL=https://sachet.ndma.gov.in/api

# --- ML / INTERNAL SERVICES --------------------------------------------------
# Internal ML model service endpoint
MODEL_SERVICE_URL=http://localhost:9000

# --- FEATURE FLAGS -----------------------------------------------------------
# Enable mock providers and fake responses for local testing
ENABLE_MOCK_MODE=false
# Enable structured application logging
ENABLE_LOGGING=true


# ── B2B Hub API (now configurable via env var B2B_API_ENABLED) ───────────────────────────────────────────────────────────────
B2B_API_ENABLED=true

# ── Referral Reward ───────────────────────────────────────────────────────────
REFERRAL_REWARD_INR=50.0
